{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*",
    "App.tsx",
    "index.tsx",
    "types.ts",
    "vite-env.d.ts",
    "components/**/*",
    "services/**/*",
    "constants/**/*",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true
  }
}
