rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // ==========================================
    // PUBLIC ACCESS FOR CAREER PAGES
    // ==========================================
    
    // Companies collection - PUBLIC READ for career pages
    match /companies/{companyId} {
      allow read: if true; // ✅ Allow public read for career pages
      allow write: if isAuthenticated();
    }
    
    // Jobs collection - PUBLIC READ for career pages
    match /jobs/{jobId} {
      allow read: if true; // ✅ Allow public read for job listings
      allow write: if isAuthenticated();
    }
    
    // Assessment Invites - PUBLIC READ for access code verification
    match /assessment_invites/{inviteId} {
      allow read: if true; // ✅ Allow public read for access code verification
      allow create: if isAuthenticated(); // Only authenticated users can create
      allow update, delete: if isAuthenticated(); // Only authenticated users can modify
    }
    
    // Job Applications - PUBLIC CREATE for career page submissions
    match /job_applications/{applicationId} {
      allow read: if isAuthenticated();
      allow create: if true; // ✅ Allow public create for job applications
      allow update, delete: if isAuthenticated();
    }
    
    // ==========================================
    // AUTHENTICATED-ONLY COLLECTIONS
    // ==========================================
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Interview sessions - authenticated only
    match /interview_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Stats - authenticated only
    match /stats/{statId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // All other collections - allow authenticated access
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}